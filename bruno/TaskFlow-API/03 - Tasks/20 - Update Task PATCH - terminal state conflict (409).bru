meta {
  name: 20 - Update Task PATCH - terminal state conflict (409)
  type: http
  seq: 20
}

patch {
  url: {{baseUrl}}/api/v1/tasks/{{taskId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "description": "Should not be applied, task is DONE",
    "version": {{taskVersion}}
  }
}

tests {
  test("returns 409, DONE is a terminal state", function () {
    expect(res.getStatus()).to.equal(409);
  });
}
