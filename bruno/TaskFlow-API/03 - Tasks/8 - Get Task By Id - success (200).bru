meta {
  name: 8 - Get Task By Id - success (200)
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/v1/tasks/{{taskId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

tests {
  test("returns 200 with the task", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.id).to.equal(Number(bru.getEnvVar("taskId")));
  });
}
