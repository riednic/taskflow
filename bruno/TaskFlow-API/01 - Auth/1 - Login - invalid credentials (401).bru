meta {
  name: 1 - Login - invalid credentials (401)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{adminEmail}}",
    "password": "definitely-wrong-password"
  }
}

tests {
  test("returns 401", function () {
    expect(res.getStatus()).to.equal(401);
  });
}
