meta {
  name: 9 - Get User By Id - as Admin (200)
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/api/v1/users/{{memberId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

tests {
  test("returns 200 with the member user", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.id).to.equal(Number(bru.getEnvVar("memberId")));
  });
}
