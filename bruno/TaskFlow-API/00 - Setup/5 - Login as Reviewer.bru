meta {
  name: 5 - Login as Reviewer
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{reviewerEmail}}",
    "password": "{{reviewerPassword}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("reviewerToken", res.body.token);
  }
}

tests {
  test("returns 200 with a token", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.token).to.be.a("string");
  });
}
