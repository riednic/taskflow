meta {
  name: 4 - Login as Member
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{memberEmail}}",
    "password": "{{memberPassword}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("memberToken", res.body.token);
  }
}

tests {
  test("returns 200 with a token", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.token).to.be.a("string");
  });
}
