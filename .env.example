# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=taskflow

# Application
SERVER_PORT=8080

# JWT
JWT_SECRET=please-generate-a-256-bit-base64-secret-e.g.-openssl-rand--base64-32
JWT_EXPIRATION_SECONDS=3600

# Initial admin seeding (only used on first startup, when no ADMIN user exists yet)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@taskflow.local
ADMIN_PASSWORD=please-change-me